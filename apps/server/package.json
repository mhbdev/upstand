{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc --noEmit",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun --env-file=apps/server/.env --cwd ../.. --hot apps/server/src/index.ts",
    "start": "bun run dist/index.mjs",
    "lint": "biome check ."
  },
  "dependencies": {
    "@circulo-ai/di": "catalog:",
    "@hono/trpc-server": "^0.4.2",
    "@trpc/server": "catalog:",
    "@upstand/api": "workspace:*",
    "@upstand/auth": "workspace:*",
    "@upstand/db": "workspace:*",
    "@upstand/domain": "workspace:*",
    "@upstand/env": "workspace:*",
    "@upstand/infrastructure": "workspace:*",
    "@upstand/platform": "workspace:*",
    "@upstand/redis": "workspace:*",
    "@upstand/repositories": "workspace:*",
    "@upstand/usecases": "workspace:*",
    "ai": "^7.0.22",
    "drizzle-orm": "catalog:",
    "evlog": "catalog:",
    "hono": "catalog:",
    "ssh2": "^1.17.0",
    "swagger-ui-dist": "^5.32.11",
    "trpc-to-openapi": "^3.3.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/ssh2": "^1.15.5",
    "@upstand/config": "workspace:*",
    "tsdown": "^0.22.13",
    "typescript": "catalog:"
  }
}
