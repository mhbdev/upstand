# Local development defaults. Never use these values for a public deployment.
NODE_ENV=development
DATABASE_URL=postgresql://postgres:password@localhost:5432/upstand
REDIS_URL=redis://localhost:6379
BETTER_AUTH_SECRET=local-development-secret-change-before-exposing-any-service
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3001
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
SSH_KEY_ENCRYPTION_KEY_V1=local-development-ssh-key-encryption-key-change-me

# Optional integrations
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
