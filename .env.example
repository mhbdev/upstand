# Used only by docker-compose.local.yml. The setup script copies this file to
# .env when it does not already exist.
POSTGRES_PASSWORD=upstand-local-password
BETTER_AUTH_SECRET=upstand-local-development-secret-that-is-at-least-32-characters
# Optional trusted MCP Apps servers; leave empty to keep the default tool surface.
UPGAL_MCP_SERVERS=[]
