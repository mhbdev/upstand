# Used only by docker-compose.local.yml. The setup script copies this file to
# .env when it does not already exist.
POSTGRES_PASSWORD=upstand-local-password
BETTER_AUTH_SECRET=upstand-local-development-secret-that-is-at-least-32-characters
# Mode configuration: false for Self-Hosted (default, single owner setup), true for Cloud (open sign-ups).
IS_CLOUD=false
NEXT_PUBLIC_IS_CLOUD=false
# Optional explicit super admin / instance owner user ID override.
UPSTAND_INSTANCE_OWNER_USER_ID=
# Optional trusted MCP Apps servers; leave empty to keep the default tool surface.
UPGAL_MCP_SERVERS=[]
# Optional public web search for UpGal. Obtain a Brave Search API key and keep
# this value server-side; UpGal returns only bounded, cited result metadata.
UPGAL_WEB_SEARCH_API_KEY=
# Optional HTTPS-compatible Brave Search API endpoint override.
UPGAL_WEB_SEARCH_BASE_URL=https://api.search.brave.com/res/v1/web/search
