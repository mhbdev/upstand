{
  "name": "@upstand/platform",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts",
      "default": "./src/*.ts"
    },
    "./*/*": {
      "types": "./src/*/*.ts",
      "import": "./src/*/*.ts",
      "default": "./src/*/*.ts"
    }
  },
  "types": "./src/index.ts",
  "scripts": {
    "check-types": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@upstand/env": "workspace:*",
    "micro-key-producer": "^0.9.0",
    "ssh2": "^1.17.0",
    "sshpk": "^1.18.0"
  },
  "devDependencies": {
    "@types/ssh2": "^1.15.5",
    "@types/sshpk": "^1.17.5",
    "@upstand/config": "workspace:*",
    "typescript": "catalog:"
  }
}
