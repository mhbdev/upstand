{
  "name": "@upstand/infrastructure",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts",
      "default": "./src/*.ts"
    },
    "./*/*": {
      "types": "./src/*/*.ts",
      "import": "./src/*/*.ts",
      "default": "./src/*/*.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@upstand/domain": "workspace:*",
    "@upstand/usecases": "workspace:*",
    "nodemailer": "^9.0.3"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.1",
    "@upstand/config": "workspace:*",
    "typescript": "catalog:"
  }
}
