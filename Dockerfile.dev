FROM oven/bun:1.3.14 AS dev
WORKDIR /app

# Copy lockfile and package configurations to cache dependencies
COPY package.json bun.lock tsconfig.json ./
COPY apps/web/package.json ./apps/web/
COPY apps/server/package.json ./apps/server/
COPY apps/fumadocs/package.json ./apps/fumadocs/
COPY packages/db/package.json ./packages/db/
COPY packages/env/package.json ./packages/env/
COPY packages/api/package.json ./packages/api/
COPY packages/auth/package.json ./packages/auth/
COPY packages/config/package.json ./packages/config/
COPY packages/ui/package.json ./packages/ui/
COPY packages/repositories/package.json ./packages/repositories/

# Install workspace dependencies without running postinstall scripts (which require source files)
RUN bun install --ignore-scripts

# Copy project source
COPY . .

# Run postinstall scripts now that source files are copied
RUN cd apps/fumadocs && bun run postinstall
