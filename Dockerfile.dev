FROM oven/bun:1.3.14 AS dev
WORKDIR /app

# The server drives the host Docker daemon for Swarm resources and uses rclone
# for backup upload/download streams. Keep local development behavior aligned
# with the production runner image.
RUN apt-get update && apt-get install -y --no-install-recommends \
    docker-cli \
    rclone \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Copy lockfile and package configurations to cache dependencies
COPY package.json bun.lock tsconfig.json ./
COPY apps/web/package.json ./apps/web/
COPY apps/server/package.json ./apps/server/
COPY apps/fumadocs/package.json ./apps/fumadocs/
COPY packages/db/package.json ./packages/db/
COPY packages/env/package.json ./packages/env/
COPY packages/api/package.json ./packages/api/
COPY packages/auth/package.json ./packages/auth/
COPY packages/config/package.json ./packages/config/
COPY packages/platform/package.json ./packages/platform/
COPY packages/ui/package.json ./packages/ui/
COPY packages/redis/package.json ./packages/redis/
COPY packages/repositories/package.json ./packages/repositories/
COPY packages/domain/package.json ./packages/domain/
COPY packages/usecases/package.json ./packages/usecases/

# Install workspace dependencies without running postinstall scripts (which require source files)
RUN bun install --ignore-scripts

# Copy project source
COPY . .

# Run postinstall scripts now that source files are copied
RUN cd apps/fumadocs && bun run postinstall
