FROM oven/bun:1.3.14 AS dev
WORKDIR /app

# The server drives the host Docker daemon for Swarm resources and uses rclone
# for backup upload/download streams. Keep local development behavior aligned
# with the production runner image.
RUN apt-get update && apt-get install -y --no-install-recommends \
    docker-cli \
    curl \
    python3 \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

ARG UPSTAND_RCLONE_VERSION=1.74.4
ARG TARGETARCH=amd64
RUN case "$TARGETARCH" in \
      amd64) RCLONE_ARCH="amd64" ;; \
      arm64) RCLONE_ARCH="arm64" ;; \
      *) echo "Unsupported rclone architecture: $TARGETARCH" >&2; exit 1 ;; \
    esac \
    && curl --fail --location --retry 3 --retry-all-errors \
      "https://downloads.rclone.org/v${UPSTAND_RCLONE_VERSION}/rclone-v${UPSTAND_RCLONE_VERSION}-linux-${RCLONE_ARCH}.zip" \
      --output /tmp/rclone.zip \
    && python3 -c "import zipfile; zipfile.ZipFile('/tmp/rclone.zip').extractall('/tmp/rclone')" \
    && install "/tmp/rclone/rclone-v${UPSTAND_RCLONE_VERSION}-linux-${RCLONE_ARCH}/rclone" /usr/local/bin/rclone \
    && rm -rf /tmp/rclone /tmp/rclone.zip \
    && rclone version

# Copy lockfile and package configurations to cache dependencies
COPY package.json bun.lock tsconfig.json ./
COPY apps/web/package.json ./apps/web/
COPY apps/server/package.json ./apps/server/
COPY apps/fumadocs/package.json ./apps/fumadocs/
COPY packages/db/package.json ./packages/db/
COPY packages/env/package.json ./packages/env/
COPY packages/api/package.json ./packages/api/
COPY packages/auth/package.json ./packages/auth/
COPY packages/config/package.json ./packages/config/
COPY packages/platform/package.json ./packages/platform/
COPY packages/ui/package.json ./packages/ui/
COPY packages/redis/package.json ./packages/redis/
COPY packages/repositories/package.json ./packages/repositories/
COPY packages/domain/package.json ./packages/domain/
COPY packages/usecases/package.json ./packages/usecases/
COPY packages/infrastructure/package.json ./packages/infrastructure/

# Install workspace dependencies without running postinstall scripts (which require source files)
RUN bun install --ignore-scripts

# Copy project source
COPY . .

# Run postinstall scripts now that source files are copied
RUN cd apps/fumadocs && bun run postinstall
