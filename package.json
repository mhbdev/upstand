{
  "name": "upstand",
  "version": "0.1.84",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "typescript": "^6",
      "@types/bun": "^1.3.14",
      "hono": "^4.12.27",
      "@trpc/server": "^11.18.0",
      "better-auth": "1.6.23",
      "@better-auth/api-key": "1.6.23",
      "evlog": "^2.19.2",
      "next-themes": "^0.4.6",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "sonner": "^2.0.7",
      "@trpc/client": "^11.18.0",
      "@tailwindcss/postcss": "^4.3.2",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.3.2",
      "drizzle-orm": "^0.45.2",
      "@circulo-ai/di": "3.1.0",
      "@hugeicons/core-free-icons": "^4.2.2",
      "@hugeicons/react": "^1.1.9",
      "react-day-picker": "^10.0.1",
      "embla-carousel-react": "^8.6.0",
      "recharts": "3.8.0",
      "cmdk": "^1.1.1",
      "input-otp": "^1.4.2",
      "react-resizable-panels": "^4.12.1",
      "@better-auth-ui/core": "^1.1.9",
      "@better-auth-ui/react": "^1.1.9",
      "bullmq": "^5.41.3"
    }
  },
  "overrides": {
    "better-auth": "1.6.23",
    "drizzle-orm": "0.45.2",
    "esbuild": "0.28.1",
    "linkify-it": "6.0.0",
    "lodash": "4.18.1",
    "postcss": "8.5.19"
  },
  "type": "module",
  "scripts": {
    "setup": "bun scripts/setup.ts",
    "dev": "bun scripts/dev.ts",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "biome format --write .",
    "dev:web": "turbo run dev -F web",
    "dev:server": "turbo run dev -F server",
    "db:push": "turbo run db:push -F @upstand/db",
    "db:studio": "turbo run db:studio -F @upstand/db",
    "db:generate": "turbo run db:generate -F @upstand/db",
    "db:migrate": "turbo run db:migrate -F @upstand/db",
    "db:start": "docker compose -f docker-compose.local.yml up -d postgres redis",
    "db:watch": "docker compose -f docker-compose.local.yml up postgres redis",
    "db:stop": "docker compose -f docker-compose.local.yml stop postgres redis",
    "db:down": "docker compose -f docker-compose.local.yml down postgres redis",
    "docker:build": "docker compose -f docker-compose.local.yml build",
    "docker:up": "docker compose -f docker-compose.local.yml up -d --build",
    "docker:down": "docker compose -f docker-compose.local.yml down",
    "docker:logs": "docker compose -f docker-compose.local.yml logs -f",
    "docker:local:build": "docker compose -f docker-compose.local.yml build",
    "docker:local:up": "docker compose -f docker-compose.local.yml up -d --build",
    "docker:local:down": "docker compose -f docker-compose.local.yml down",
    "docker:local:logs": "docker compose -f docker-compose.local.yml logs -f",
    "check": "biome check --write .",
    "knip": "knip --reporter compact",
    "security:scan": "bun audit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/bun": "^1.3.14",
    "@upstand/config": "workspace:*",
    "knip": "^6.27.0",
    "turbo": "^2.10.5",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.14"
}
