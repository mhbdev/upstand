{
  "name": "upstand",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "typescript": "^6",
      "@types/bun": "^1.3.14",
      "hono": "^4.12.27",
      "@trpc/server": "^11.18.0",
      "better-auth": "1.6.23",
      "evlog": "^2.19.2",
      "lucide-react": "^1.23.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "sonner": "^2.0.7",
      "@trpc/client": "^11.18.0",
      "@tailwindcss/postcss": "^4.3.2",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.3.2",
      "drizzle-orm": "^0.45.2",
      "@circulo-ai/di": "3.1.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "cli": "bun run packages/cli/src/index.ts",
    "gc": "bun run packages/cli/src/index.ts create",
    "lint": "turbo run lint",
    "format": "biome format --write .",
    "dev:web": "turbo run dev -F web",
    "dev:server": "turbo run dev -F server",
    "db:push": "turbo run db:push -F @upstand/db",
    "db:studio": "turbo run db:studio -F @upstand/db",
    "db:generate": "turbo run db:generate -F @upstand/db",
    "db:migrate": "turbo run db:migrate -F @upstand/db",
    "db:start": "docker compose up -d postgres",
    "db:watch": "docker compose up postgres",
    "db:stop": "docker compose stop postgres",
    "db:down": "docker compose down postgres",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:local:build": "docker compose -f docker-compose.local.yml build",
    "docker:local:up": "docker compose -f docker-compose.local.yml up -d --build",
    "docker:local:down": "docker compose -f docker-compose.local.yml down",
    "docker:local:logs": "docker compose -f docker-compose.local.yml logs -f",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@opentui/core": "^0.4.3",
    "@upstand/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/bun": "catalog:",
    "@upstand/config": "workspace:*",
    "ts-morph": "^28.0.0",
    "turbo": "^2.10.2",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.14"
}
